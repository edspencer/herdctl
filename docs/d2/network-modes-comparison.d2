# Network Modes Comparison - Bridge vs Host
# Shows Docker networking options for Claude Code agents

direction: right

# ============================================================
# Bridge Mode container (top) - navy for top-level grouping
# ============================================================
bridge-mode: {
  label: "Bridge Mode (default)"
  style.fill: "#1e3a5f"
  style.stroke: "#142842"
  style.stroke-width: 2
  style.font-color: "#ffffff"
  style.border-radius: 12
  style.shadow: true
  style.font-size: 16

  container: {
    label: "Agent Container\nOwn network namespace"
    style.fill: "#93c5fd"
    style.stroke: "#60a5fa"
    style.stroke-width: 2
    style.font-color: "#1e293b"
    style.border-radius: 8
    style.font-size: 12
    style.bold: true
  }

  docker-bridge: {
    label: "Docker Bridge\n+ NAT"
    style.fill: "#6ee7b7"
    style.stroke: "#34d399"
    style.stroke-width: 2
    style.font-color: "#064e3b"
    style.border-radius: 8
    style.font-size: 12
    style.bold: true
  }

  container -> docker-bridge: {
    style.stroke: "#34d399"
    style.stroke-width: 2
  }
}

# ============================================================
# Host Mode container (bottom) - navy for top-level grouping
# ============================================================
host-mode: {
  label: "Host Mode"
  style.fill: "#1e3a5f"
  style.stroke: "#142842"
  style.stroke-width: 2
  style.font-color: "#ffffff"
  style.border-radius: 12
  style.shadow: true
  style.font-size: 16

  container: {
    label: "Agent Container\nShares host namespace"
    style.fill: "#93c5fd"
    style.stroke: "#60a5fa"
    style.stroke-width: 2
    style.font-color: "#1e293b"
    style.border-radius: 8
    style.font-size: 12
    style.bold: true
  }

  host-network: {
    label: "Host Network\nStack"
    style.fill: "#fbbf24"
    style.stroke: "#d97706"
    style.stroke-width: 2
    style.font-color: "#451a03"
    style.border-radius: 8
    style.font-size: 12
    style.bold: true
  }

  container -> host-network: {
    style.stroke: "#d97706"
    style.stroke-width: 2
  }
}

# ============================================================
# External services (right side)
# ============================================================
internet: {
  label: "Internet"
  style.fill: "#fdba74"
  style.stroke: "#f59e0b"
  style.stroke-width: 2
  style.font-color: "#451a03"
  style.border-radius: 8
  style.font-size: 14
  style.bold: true
}

anthropic-api: {
  label: "Anthropic API"
  shape: cylinder
  style.fill: "#fb923c"
  style.stroke: "#f97316"
  style.stroke-width: 2
  style.font-color: "#431407"
  style.font-size: 14
  style.bold: true
}

# ============================================================
# Summary labels (right side, below connections)
# ============================================================
bridge-label: {
  label: "Isolated + Outbound access"
  style.fill: "#6ee7b7"
  style.stroke: "#34d399"
  style.stroke-width: 2
  style.font-color: "#064e3b"
  style.border-radius: 8
  style.font-size: 11
  style.bold: true
}

host-label: {
  label: "No isolation + Full host access"
  style.fill: "#fbbf24"
  style.stroke: "#d97706"
  style.stroke-width: 2
  style.font-color: "#451a03"
  style.border-radius: 8
  style.font-size: 11
  style.bold: true
}

# ============================================================
# Connections - Bridge path
# ============================================================
bridge-mode.docker-bridge -> internet: {
  style.stroke: "#34d399"
  style.stroke-width: 2
}

# ============================================================
# Connections - Host path
# ============================================================
host-mode.host-network -> internet: {
  style.stroke: "#d97706"
  style.stroke-width: 2
}

# ============================================================
# Internet to Anthropic API
# ============================================================
internet -> anthropic-api: {
  style.stroke: "#f97316"
  style.stroke-width: 2
}

# ============================================================
# Dashed lines to labels
# ============================================================
bridge-mode -> bridge-label: {
  style.stroke: "#34d399"
  style.stroke-width: 1
  style.stroke-dash: 4
}

host-mode -> host-label: {
  style.stroke: "#d97706"
  style.stroke-width: 1
  style.stroke-dash: 4
}
