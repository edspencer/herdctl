  style.stroke: "#f59e0b"
  style.stroke-width: 2
  style.font-color: "#451a03"
  style.border-radius: 8
  style.font-size: 13
  style.bold: true
}

api-jobs: {
  label: "JobManager.getJobs()"
  style.fill: "#c4b5fd"
  style.stroke: "#a78bfa"
  style.stroke-width: 2
  style.font-color: "#2e1065"
  style.border-radius: 8
  style.font-size: 13
  style.bold: true
}

api-job: {
  label: "JobManager.getJob() / streamJobOutput()"
  style.fill: "#22d3ee"
  style.stroke: "#06b6d4"
  style.stroke-width: 2
  style.font-color: "#083344"
  style.border-radius: 8
  style.font-size: 13
  style.bold: true
}

api-cancel: {
  label: "cancelJob()"
  style.fill: "#fb923c"
  style.stroke: "#f97316"
  style.stroke-width: 2
  style.font-color: "#431407"
  style.border-radius: 8
  style.font-size: 13
  style.bold: true
}

api-sessions: {
